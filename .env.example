# Database
DATABASE_URL="postgresql://<username>:<password>@localhost:5432/<database>?schema=public"

# Cloudinary
CLOUDINARY_CLOUD_NAME="<cloud-name>"
CLOUDINARY_API_KEY="<cloudinary-api-key>"
CLOUDINARY_API_SECRET="<cloudinary-api-secret>"

# Better Auth
BETTER_AUTH_SECRET="<generate-a-32+-char-secret>"
BETTER_AUTH_URL="http://localhost:3000"

# OAuth Providers
GOOGLE_CLIENT_ID="<google-client-id>"
GOOGLE_CLIENT_SECRET="<google-client-secret>"
GITHUB_CLIENT_ID="<github-client-id>"
GITHUB_CLIENT_SECRET="<github-client-secret>"
SEED_PROJECTS_USER_ID="<user-id>"

# Public site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
SITE_OWNER_NAME="Your Name"
SITE_OWNER_TITLE="Full-stack Developer"
SITE_OWNER_TAGLINE="I build fast, accessible web experiences."
SITE_OWNER_USER_ID="<user-id-for-hero-profile>"

# Resend (contact form)
RESEND_API_KEY="re_xxxxxxxx"
RESEND_FROM_EMAIL="Portfolio <onboarding@resend.dev>"
CONTACT_TO_EMAIL="you@example.com"

# OpenRouter (portfolio Ask tab in search)
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxx"
